generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// MVP Phase 1: Only User, ChatSession, LLMLog
// Auth is handled by Supabase Auth (JWT in headers)
// Phase 2 will add: CVAnalysis, JobOffer, UserUsage

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  supabaseId String  @unique  // Supabase Auth UID

  // Profile data
  profile   Json?
  role      String @default("user")  // 'user' | 'admin'

  // Personal info
  nom       String?
  prenom    String?
  age       Int?

  // Professional profile
  domaine          String?   // 'developpement' | 'data' | 'design' | 'marketing' | 'finance' | 'product' | 'autre'
  sousDomaine      String?
  niveau           String?   // 'junior' | 'confirme' | 'senior' | 'expert'
  postesRecherches Json?     // string[]
  profileCompletedAt    DateTime?
  onboardingCompletedAt DateTime?

  // CV Analysis (keep for latest analysis)
  cvUrl            String?   // Supabase Storage path
  cvText           String?   // Extracted text from PDF
  cvAnalysis       Json?     // { score: 0-100, strengths[], improvements[], suggestions[] }
  cvAnalysisAt     DateTime?
  cvAnalysisCount  Int @default(0)  // rate limit: max 2/day

  // Chat Reports
  chatReportCount  Int @default(0)  // rate limit: max 4/day

  // Relations
  chatSessions ChatSession[]
  chatReports  ChatReport[]
  cvAnalyses   CVAnalysis[]
  llmLogs      LLMLog[]

  // Admin controls
  suspendedAt DateTime?

  // RGPD: soft delete support
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([supabaseId])
  @@index([deletedAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Chat metadata
  title     String   @default("Untitled Chat")

  // Messages array (encrypted): [{role: "user"|"assistant", content: string, tokens: number}, ...]
  messages  Json     @default("[]")

  // Session stats
  totalTurns    Int       @default(0)
  averageScore  Float?

  // LLM usage for this session
  inputTokens   Int       @default(0)
  outputTokens  Int       @default(0)
  costUSD       Float     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  scoreBreakdowns ScoreBreakdown[]
  chatReports ChatReport[]

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
}

model ChatReport {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Report content
  summary     String?          // Narrative summary of the session
  feedback    Json?            // Array of feedback points
  strengths   Json @default("[]")    // string[]
  improvements Json @default("[]")   // string[]
  suggestions Json @default("[]")    // string[]

  // Session metrics at analysis time
  messageCount Int @default(0)  // Number of user messages at analysis time
  averageScore Float?           // Average score of the session

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  @@unique([sessionId, createdAt])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model CVAnalysis {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CV metadata
  cvUrl       String?        // Supabase Storage path
  cvText      String?        // Extracted text from PDF

  // Analysis results
  score       Int            // 0-100
  strengths   Json @default("[]")    // string[]
  improvements Json @default("[]")   // string[]
  suggestions Json @default("[]")    // string[]

  createdAt   DateTime @default(now())

  // Relations
  @@index([userId])
  @@index([createdAt])
}

model ScoreBreakdown {
  id            String   @id @default(cuid())
  sessionId     String
  messageIndex  Int

  // 5-criterion scoring breakdown
  pertinence    Int      // 0-30
  clarte        Int      // 0-20 (without accent for DB)
  exemples      Int      // 0-20
  profondeur    Int      // 0-20
  communication Int      // 0-10
  totalScore    Int      // sum of all criteria

  createdAt     DateTime @default(now())

  // Relation
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Ensure one breakdown per message
  @@unique([sessionId, messageIndex])
  @@index([sessionId])
}

model LLMLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // API call details
  model         String   // "gpt-4o-mini", "gpt-4o"
  feature       String   // "chat_turn", "summarization"

  inputTokens   Int
  outputTokens  Int
  costUSD       Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
