# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Database (Prisma - get from Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ganus
DIRECT_URL=postgresql://postgres:password@localhost:5432/ganus

# Encryption (Local only - never commit real keys)
ENCRYPTION_KEY=your-32-char-hex-key-here-change-in-production

# OpenAI (Phase 2)
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Rate Limiting (messages per hour per user — use 6 for dev, 20 for prod)
RATE_LIMIT_MESSAGES_PER_HOUR=20

# Admin
ADMIN_SECRET=your-strong-random-secret
