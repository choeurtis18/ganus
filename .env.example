# Supabase (Database + Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Database (Prisma)
# Use the connection pooler (port 6543) for DATABASE_URL and the direct connection (port 5432) for DIRECT_URL
# Both are available in Supabase dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:password@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Rate Limiting (messages per hour per user — use 6 for dev, 20 for prod)
RATE_LIMIT_MESSAGES_PER_HOUR=20

# Admin
ADMIN_SECRET=your-strong-random-secret

# Supabase Storage (CV uploads — create bucket 'cvs' in Supabase dashboard, set to private)
# No extra env needed — uses SUPABASE_SERVICE_ROLE_KEY for storage operations
